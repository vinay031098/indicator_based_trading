# ─── Runtime ───────────────────────────────────────────────────────
PRODUCTION=0
LOG_LEVEL=INFO
DOMAIN=localhost:5000

# ─── Flask ─────────────────────────────────────────────────────────
# Generate: python manage.py gen-secret-key
SECRET_KEY=

# ─── Dashboard login (server-side auth) ────────────────────────────
DASHBOARD_USER=Trader
# Generate: python manage.py hash-password 'your-password'
DASHBOARD_PASSWORD_HASH=

# ─── Fyers API (https://myapi.fyers.in/dashboard) ──────────────────
FYERS_APP_ID=
FYERS_SECRET_ID=
# Must match the redirect URI in https://myapi.fyers.in/dashboard exactly.
# Production example: https://belezabrasileiro.com/auth/callback
FYERS_REDIRECT_URI=
# All Fyers v3 calls (OAuth + trading + data) use api-t1.
FYERS_AUTH_API_BASE=https://api-t1.fyers.in/api/v3
FYERS_API_BASE=https://api-t1.fyers.in/api/v3
FYERS_DATA_API_BASE=https://api-t1.fyers.in/data
# Generate: python manage.py gen-encryption-key  (encrypts the saved token at rest)
TOKEN_ENCRYPTION_KEY=

# ─── LLM (GitHub Models — PAT with models:read) ────────────────────
GITHUB_TOKEN=
GEMINI_API_KEY=

# ─── Persistence ───────────────────────────────────────────────────
# Dev default is SQLite; in production use Postgres, e.g.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///analysis_data.db

# ─── Background jobs / cache (optional; in-process fallback if unset) ─
REDIS_URL=

# ─── Analysis defaults ─────────────────────────────────────────────
MIN_SCORE_THRESHOLD=2
ANALYSIS_PERIOD_DAYS=365
